// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  username   String   @unique
  password   String
  role       String
  companyId  String?
  company    Company? @relation(fields: [companyId], references: [id])

  createdAt  DateTime @default(now())
}

model Company {
  id        String   @id @default(cuid())
  name      String

  users     User[]
  profile   Profile?
  documents Document[]
  controls  Control[]
  risks     Risk[]
  uploads   Upload[]

  createdAt DateTime @default(now())
}

model Profile {
  id         String  @id @default(cuid())
  companyId  String  @unique
  company    Company @relation(fields: [companyId], references: [id])

  industry   String?
  size       String?
  hasCloud   Boolean @default(false)
  hasPII     Boolean @default(false)
  hasCriticalSystems Boolean @default(false)
}

model Document {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])

  name       String
  category   String
  status     String
  required   Boolean  @default(true)
  reason     String?

  createdAt  DateTime @default(now())
}

model Control {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])

  code       String
  title      String
  status     String
  applicable Boolean  @default(true)
  justification String?

  createdAt  DateTime @default(now())
}

model Risk {
  id                  String   @id @default(cuid())
  companyId           String
  company             Company  @relation(fields: [companyId], references: [id])

  title               String
  asset               String

  likelihood          Int
  impact              Int

  residualLikelihood  Int
  residualImpact      Int

  status              String

  createdAt           DateTime @default(now())
}

model Upload {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])

  name         String
  mimeType     String
  sizeBytes    Int
  path         String

  analysisNotes String?

  createdAt    DateTime @default(now())
}
