// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  COMPLIANCE_MANAGER
  CLIENT_ADMIN
}

enum ControlStatus {
  PLANNED
  IMPLEMENTED
  APPROVED
  NOT_APPLICABLE
}

enum DocumentStatus {
  DRAFT
  APPROVED
  NOT_REQUIRED
}

enum RiskStatus {
  OPEN
  TREATMENT_PLANNED
  CLOSED
}

model User {
  id           String   @id @default(cuid())
  name         String
  username     String   @unique
  email        String   @unique
  passwordHash String
  role         UserRole
  companyId    String?
  company      Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])
}

model Company {
  id         String            @id
  name       String
  framework  String
  ownerName  String
  industry   String

  profile    CompanyProfile?
  controls   CompanyControl[]
  risks      CompanyRisk[]
  documents  CompanyDocument[]
  uploads    CompanyUpload[]
  tasks      Task[]
  users      User[]

  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model CompanyProfile {
  id                         String   @id @default(cuid())
  companyId                  String   @unique
  company                    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerDescription        String   @default("")
  industry                   String   @default("General")
  companySize                String   @default("SMB")
  remoteWorkforce            Boolean  @default(true)
  physicalOfficeControl      Boolean  @default(false)
  softwareDevelopment        Boolean  @default(true)
  cloudHosted                Boolean  @default(true)
  personalDataProcessing     Boolean  @default(true)
  specialCategoryData        Boolean  @default(false)
  paymentProcessing          Boolean  @default(false)
  regulatedMarket            Boolean  @default(false)
  suppliersCritical          Boolean  @default(true)
  businessContinuityRequired Boolean  @default(true)
  mobileDevicesUsed          Boolean  @default(true)
  privilegedAccessManaged    Boolean  @default(true)
  securityMonitoringNeeded   Boolean  @default(true)

  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model BaselineControl {
  id                String           @id @default(cuid())
  code              String           @unique
  title             String
  domain            String
  defaultApplicable Boolean          @default(true)
  rationale         String

  companyControls   CompanyControl[]

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model BaselineRisk {
  id               String   @id @default(cuid())
  key              String   @unique
  title            String
  category         String
  asset            String
  threat           String
  vulnerability    String
  likelihood       Int
  impact           Int
  residualLikelihood Int
  residualImpact   Int
  treatment        String

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model BaselineDocument {
  id         String   @id @default(cuid())
  key        String   @unique
  name       String
  category   String
  required   Boolean
  reason     String

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CompanyControl {
  id                  String        @id @default(cuid())
  companyId           String
  baselineControlId   String
  ownerName           String

  // proposta automatica del motore
  autoApplicable      Boolean       @default(true)
  autoJustification   String

  // override manuale auditor
  manualApplicable    Boolean?
  manualJustification String?

  // valore operativo attuale
  applicable          Boolean       @default(true)
  justification       String

  evidence            String        @default("")
  status              ControlStatus @default(PLANNED)

  company             Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  baselineControl     BaselineControl @relation(fields: [baselineControlId], references: [id], onDelete: Cascade)

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([companyId])
  @@index([baselineControlId])
}

model CompanyRisk {
  id                 String      @id @default(cuid())
  companyId          String
  title              String
  category           String
  asset              String
  threat             String
  vulnerability      String
  likelihood         Int
  impact             Int
  residualLikelihood Int
  residualImpact     Int
  treatment          String
  ownerName          String
  status             RiskStatus  @default(OPEN)

  company            Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([companyId])
}

model CompanyDocument {
  id         String         @id @default(cuid())
  companyId  String
  name       String
  category   String
  required   Boolean        @default(true)
  reason     String
  ownerName  String
  status     DocumentStatus @default(DRAFT)

  company    Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([companyId])
}

model CompanyUpload {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  mimeType      String
  sizeBytes     Int
  extractedText String   @default("")
  analysisNotes String?
  path          String?

  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId])
}

model Task {
  id         String   @id @default(cuid())
  companyId  String
  title      String
  assignee   String
  priority   String
  dueDate    DateTime?
  completed  Boolean  @default(false)

  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId])
}
